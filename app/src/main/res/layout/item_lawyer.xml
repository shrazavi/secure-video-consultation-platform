<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"

    android:id="@+id/lawyer_layout"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="10dp"
    app:layout_anchorGravity="center">

    <androidx.cardview.widget.CardView
        android:id="@+id/crd_lawyer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:alpha=".9"
        app:cardCornerRadius="10dp"
        app:cardElevation="8dp"
        app:cardUseCompatPadding="true"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="10dp"
        tools:layout_editor_absoluteY="10dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="2">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:orientation="vertical">

                <androidx.cardview.widget.CardView
                    android:id="@+id/crd_lawyer_prof"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_marginTop="10dp"
                    app:cardCornerRadius="50dp">

                    <TextView
                        android:id="@+id/txt_lawyer_prof"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="5dp"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="36sp" />

                    <ImageView
                        android:id="@+id/img_lawyer"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/txt_lawyer_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="false"
                    android:layout_centerVertical="false"
                    android:layout_gravity="center"
                    android:layout_marginTop="10dp"
                    android:gravity="center_horizontal"
                    android:textColor="#000000"
                    android:textSize="20sp"
                    tools:text="زهرا سادات رضوی" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <RatingBar
                        android:id="@+id/ratingbar_lawyer"
                        style="@android:style/Widget.DeviceDefault.Light.RatingBar.Small"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"


                        android:numStars="5"

                        android:rating="4.5"
                        android:secondaryProgressTint="@android:color/transparent" />

                    <TextView
                        android:id="@+id/txt_lawyer_rating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxLength="3"
                        android:text="4.555555555555"
                        android:textColor="#000000"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="250dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/txt_lawyer_type"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"


                            android:layout_marginStart="5dp"
                            android:layout_marginEnd="5dp"
                            android:textColor="#000000"
                            android:textSize="14sp"
                            tools:text="کانون وکلای استان اصفهان" />

                        <TextView
                            android:id="@+id/txt_lawyer_base"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"


                            android:layout_marginStart="5dp"
                            android:layout_marginEnd="5dp"
                            android:textColor="#000000"
                            android:textSize="14sp"
                            tools:text="وکیل پایه یک دادگستری" />

                        <TextView
                            android:id="@+id/txt_lawyer_experience"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"


                            android:layout_marginStart="5dp"
                            android:layout_marginEnd="5dp"
                            android:gravity="start"
                            android:textColor="#000000"
                            android:textSize="14sp"
                            tools:text="با 10 سال سابقه" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </RelativeLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>