<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"

    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/lay_chat"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="10dp"
    android:layout_marginRight="10dp"
    android:gravity="right"
    android:orientation="vertical"
    android:paddingTop="10dp"
    android:paddingBottom="5dp">


    <LinearLayout
        android:id="@+id/linearChatClick"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:background="@drawable/deletechat"
        android:gravity="right|end"
        android:orientation="vertical">

        <RelativeLayout
            android:id="@+id/laypdf"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center|center_horizontal|center_vertical"
            android:layout_weight="0.9"
            android:gravity="center|clip_vertical|center_vertical"
            android:visibility="gone">

            <ImageView
                android:id="@+id/imagepdf"
                android:layout_width="300dp"
                android:layout_height="200dp"
                android:background="#FFFFFF" />

            <ImageView
                android:id="@+id/imgpdf"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_centerInParent="true"
                android:background="@drawable/picdown"
                android:visibility="visible" />

        </RelativeLayout>

        <LinearLayout
            android:id="@+id/lay_voise_chat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="start|center_vertical"
            android:orientation="horizontal"
            android:visibility="visible">

            <ImageView
                android:id="@+id/img_play_voise"
                android:layout_width="30dp"
                android:layout_height="40dp"
                android:layout_marginEnd="10dp"
                android:visibility="visible"
                tools:srcCompat="@drawable/picvoice" />

            <TextView
                android:id="@+id/txtChatText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:textColor="#000000"
                android:textSize="17sp"
                android:visibility="visible"
                tools:text="چت من" />

        </LinearLayout>

        <RelativeLayout
            android:id="@+id/layvid"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center|center_horizontal|center_vertical"
            android:layout_weight="0.9"
            android:gravity="center|clip_vertical|center_vertical"
            android:visibility="gone">

            <ImageView
                android:id="@+id/imageView5"
                android:layout_width="300dp"
                android:layout_height="200dp"
                android:background="#000000" />

            <ImageView
                android:id="@+id/imageView4"
                android:layout_width="75dp"
                android:layout_height="75dp"
                android:layout_centerInParent="true"
                android:background="@drawable/ic_play"
                android:visibility="visible" />

        </RelativeLayout>

        <ImageView
            android:id="@+id/img_chat"
            android:layout_width="300dp"
            android:layout_height="200dp"
            android:layout_weight="0.9"
            android:visibility="gone"
            tools:srcCompat="@tools:sample/avatars" />

        <LinearLayout
            android:id="@+id/laytime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_weight="0.1"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtChatTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="6dp"
                android:layout_marginBottom="3dp"
                android:textColor="#000000"
                android:textSize="15sp"
                android:textStyle="normal"
                tools:text="  Deleted Message" />

            <ImageView
                android:id="@+id/imgChatTick"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center_vertical"
                android:layout_marginRight="8dp"
                android:layout_marginBottom="4dp"
                android:visibility="visible"
                tools:srcCompat="@drawable/ic_check" />


        </LinearLayout>

    </LinearLayout>


</LinearLayout>